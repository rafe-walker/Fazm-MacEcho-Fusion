# Fazm Backend Configuration
PORT=8080
FAZM_BACKEND_SECRET=your-shared-secret-here

# RSA private key for signing subject tokens (PEM format)
VERTEX_SA_PRIVATE_KEY_PEM="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"

# OIDC issuer (must match the Cloud Run URL)
VERTEX_ISSUER=https://fazm-backend-xxxxx.run.app

# GCP Workload Identity Federation
GCP_PROJECT_NUMBER=your-project-number
GCP_WORKLOAD_POOL=fazm-desktop-pool
GCP_OIDC_PROVIDER=fazm-backend-provider
GCP_SERVICE_ACCOUNT=vertex-ai-sa@your-project.iam.gserviceaccount.com

# Vertex AI
VERTEX_PROJECT_ID=your-project-id
VERTEX_REGION=us-east5

# API keys served to authenticated clients
ANTHROPIC_API_KEY=sk-ant-...
DEEPGRAM_API_KEY=your-deepgram-key
